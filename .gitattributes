# Normalize line endings: LF in the repo, native on checkout
* text=auto eol=lf

# Windows scripts must stay CRLF
*.bat text eol=crlf

# The Gradle wrapper script must stay LF so it runs on Unix
gradlew text eol=lf

# Binary assets — never normalize
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.jar binary
*.jks binary
*.keystore binary
